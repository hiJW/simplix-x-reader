{
  "manifest_version": 3,
  "name": "SimpliX",
  "version": "1.1.0",
  "description": "在 X(Twitter) 上自动把较难的英文推文改写成更易读的英文，原地替换并保留链接/@提及/#话题/emoji。",
  "icons": {
    "16": "icons/simplix-16.png",
    "32": "icons/simplix-32.png",
    "48": "icons/simplix-48.png",
    "128": "icons/simplix-128.png"
  },
  "action": {
    "default_title": "SimpliX",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/simplix-16.png",
      "32": "icons/simplix-32.png",
      "48": "icons/simplix-48.png",
      "128": "icons/simplix-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://mobile.twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": [
        "prompts.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
